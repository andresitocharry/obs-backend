{
    "name": "dqg-backend",
    "version": "1.0.0",
    "description": "Backend for Data Quality Gate",
    "scripts": {
        "docker:local": "docker-compose up --build",
        "docker:stop": "docker-compose down",
        "docker:logs": "docker-compose logs -f",
        "docker:clean": "docker-compose down -v --rmi all",
        "docker:status": "docker ps --format \"table {{.Names}}\t{{.Status}}\t{{.Ports}}\""
    }
}